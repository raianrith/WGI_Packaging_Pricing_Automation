# Copy to .env — Supabase: Project Settings → API Keys
# https://supabase.com/dashboard/project/_/settings/api-keys
#
# VITE_SUPABASE_ANON_KEY = client-safe key only. Use either:
#   - Publishable key (sb_publishable_…) from “Publishable key”, or
#   - Legacy tab → “anon” “public” JWT (eyJ…)
# Never use Secret keys (sb_secret_…) or service_role in the browser.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Auth / Admin → Users (create & delete logins, reset passwords):
# 1) Run supabase/profiles_and_auth.sql in the SQL Editor.
# 2) Supabase → Authentication → Providers → Email: disable public sign up if you want logins only from Admin.
# 3) Deploy Edge Function supabase/functions/admin-users as "admin-users" and add secret
#    SUPABASE_SERVICE_ROLE_KEY (Project Settings → API → service_role / secret key — never in Vite env).
